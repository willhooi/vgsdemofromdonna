    width: 50%
}
.stack_footer_ecommerce {
	    padding-left: 20px;
    border-left: 15px solid #f78da7;
}
.entry-content p > a, li a {
    color: #f67c97;
    font-weight: 800;
}
.message-box {margin-bottom: 20px;}
.message-box a {color:#fff !important; display: inline-block;
            background-color: #ff9800;
            padding: 12px 24px;
            border-radius: 30px;
            text-decoration: none;
            font-weight: bold;
            transition: background-color 0.3s, transform 0.3s;
            margin: 10px 0;}
.message-box a:hover {
            background-color: #f57c00;
            transform: translateY(-3px);
        }

.message-box-bg-overlay {
            background: linear-gradient(135deg, #4a90e2, #7e57c2);
            color: white;
            border-radius: 15px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
            font-family: Arial, sans-serif;
        }.message-box.dark {
    background-color: #fff;
}.message-box-bg-overlay p {
            font-size: 16px;
            line-height: 1.6;
            margin-bottom: 15px;
}a.cta-button {color:#fff !important}
.cnv_bg_gradient_1 {
	    background: linear-gradient(120deg, #f67c98, rgb(251, 182, 192));
    border-radius: 15px;
	margin-top:-40px;
}
.cnv_section_bg_gradient_1 .section-bg {
	background: linear-gradient(180deg, #FFE4FF, transparent);
}
.cnv_section_bg_gradient_2 .section-bg {
	background: linear-gradient(360deg, rgb(255,240,243), transparent);
}
.cnv_slider_dot .flickity-page-dots {
	bottom: -30px;
}
.cnv_ceo_phu_img:before {
	position: absolute;
    z-index: -1;
    width: 100%;
    height: calc(100% - 130px);
    content: "";
    left: 50%;
    bottom: 0;
    -webkit-transform: translateX(-50%);
    -ms-transform: translateX(-50%);
    transform: translateX(-50%);
	background:white;
	border-radius:6px;
	box-shadow:0 24px 116px rgb(43 56 76 / 9%);
}
.col_ceo_phu .col-inner {
	padding: 30px;
    background: linear-gradient(145deg, #e2e8ec, #ffffff);
    border-radius: 6px;
    box-shadow: 5px 5px 15px #D1D9E6, -5px -5px 15px #ffffff;
}
.col_ceo_phu .col-inner:hover {
	background:linear-gradient(145deg, #f67c98, rgb(251, 182, 192));
	color:white !important;
}
.col_ceo_phu .col-inner:hover h3{
	color:white !important;
}
.col_ceo_phu_blog .col-inner {
	    text-align: left;
    padding: 30px;
	padding-bottom:0;
    position: relative;
    border-radius: 20px;
    background: linear-gradient(145deg, #e2e8ec, #ffffff);
    box-shadow: 5px 5px 15px #D1D9E6, -5px -5px 15px #ffffff;
    position: relative;
    z-index: 1;
    transition: 0.5s all ease-in-out;
}
.col_ceo_phu_blog .col-inner .box-image img {
	object-fit:cover;
	border-radius: 20px;
	transition: 0.5s all ease-in-out;
	width:300px !important;
	height:200px !important;
}
.col_ceo_phu_blog .title-detail {
	font-size:18px;
}
.col_ceo_phu_blog .col-inner:hover  .box-image img {
	transform: scale(.95);
}
