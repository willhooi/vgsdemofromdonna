                                                        margin-bottom: 15px;
                                                    }

                                                    .webmatrix_convert_box h2, .webmatrix_convert_box p, .webmatrix-convert-box-sub-title {
                                                        text-align: center;
                                                    }

                                                    .webmatrix_convert_box .button-action {
                                                        margin-top: 30px;
                                                        text-align: center;
                                                    }

                                                    .webmatrix_convert_box .button-action a {
                                                        border-radius: 100px;
                                                        font-weight: bold;
                                                        background: #fff;
                                                        color: #f67c98;
                                                        min-width: 120px;
                                                        height: 50px;
                                                        line-height: 50px;
                                                        padding: 0 20px;
                                                        border: 1px solid transparent;
                                                        display: inline-block;
                                                        text-align: center;
                                                        cursor: pointer;
                                                        text-transform: uppercase !important;
                                                    }

                                                    .webmatrix_convert_box .button-action a:hover {
                                                        background: #f67c98;
                                                        border-color: #fff;
                                                        color: #fff;
                                                    }
aside#custom_html-3 {
	padding:0;
}
.cnv_spa_img_header:before {
	    content: "";
    background: url(https://cnv.vn/wp-content/uploads/2023/11/background-min.png);
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    z-index: 1;
    transform: scale(1.1);
    border-radius: 9999px;
}
.cnv_spa_img_header img {
	z-index: 2;
    position: relative;
}
.banner_video_gioithieu, .banner_video_gioithieu .banner-bg{
	    border-radius: 99999px;
}
.section_header_cnv_spa:after {
	content: "";
	    height: 56rem !important;
    width: 56rem !important;
	    margin-left: auto !important;
    margin-right: auto !important;
	inset: 0 !important;
	    position: absolute !important;
	border-radius: 9999px !important;
	background-image: linear-gradient(to top left, #f67c9859, #dc262666) !important;
	filter:blur(200px)!important;
}
.amlab_img_border_top .img-inner {
	z-index:3;
}
.amlab_img_border_top .img-inner img{
	z-index:3;
	position:relative;
}
.amlab_img_border_top .img-inner:before {
    content: "";
    position: absolute;
    z-index: 1;
    background: #f67c98;
    width: 100%;
    height: 100%;
    border-radius: 70px 70px 0 0;
}
.underline_text {
	position:relative;
}
.underline_text:after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    right: 0;
    height: 4px;
    background-color: #f67c98;
    z-index: -1;
}
.cnv_feedback_content .icon-box .star-rating span:before {
	color: #ffaa17 !important;
}
.cnv_feedback_content .col-inner:before{
	position: absolute;
    left: 60px;
    top: 100%;
    border-right: 150px solid transparent;
    border-top: 45px solid #222;
    content: "";
}
.cnv_feedback_content .col-inner {
	background-image: url(https://cnv.vn/wp-content/uploads/2024/11/shape-12.png);
	background-position: left top;
    background-repeat: no-repeat;
	    background-size: contain;
	border-radius:5px;
}
.cnv_icb_border {
	align-items:center;
}
.cnv_icb_border .icon-box-img img {
	border-radius:9999px;
}

