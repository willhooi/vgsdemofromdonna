			<style>:root{--bordcolorspan:#f67c98 !important;}.ft-navi-chaton svg{border-radius:50px;}.ft-navi-chaton svg{background:#f67c98 !important;}</style><script>
(function() {
  function getParam(name) {
    return new URLSearchParams(window.location.search).get(name);
  }

  function saveUTM() {
    ['utm_source', 'utm_medium', 'utm_content'].forEach(function(key) {
      var value = getParam(key);
      if (value) {
        localStorage.setItem(key, value);
      }
    });
  }

  function fillUTM() {
    ['utm_source', 'utm_medium', 'utm_content'].forEach(function(key) {
      var value = localStorage.getItem(key) || '';
      document.querySelectorAll('[name="' + key + '"]').forEach(e => e.value = value);
    });
  }

  document.addEventListener("DOMContentLoaded", function() {
    saveUTM();
    fillUTM();
  });
})();
</script><script>
(function () {
  function trySetFormURL() {
    const input = document.getElementById("urlForm");
    if (input && !input.value) {
      input.value = window.location.href;
      console.log("[urlForm] set value to:", input.value);
      return true;
    }
    return false;
  }

  document.addEventListener("DOMContentLoaded", function () {
    // Retry tự động khi trang vừa tải (dành cho form trong footer)
    let tries = 0;
    const maxTries = 20;
    const interval = setInterval(() => {
      const success = trySetFormURL();
      tries++;
      if (success || tries >= maxTries) {
        clearInterval(interval);
        if (!success) {
          console.warn("[urlForm] not found or not set after retries.");
        }
      }
    }, 300);

    // Hook khi form CF7 chuẩn bị gửi (dù popup hay không)
    document.addEventListener("wpcf7beforesubmit", function (event) {
      trySetFormURL();
    });

    // Gán lại khi người dùng bấm nút mở popup
    document.addEventListener("click", function (e) {
      const isPopupTrigger = e.target.closest(".popup-button, .popup-trigger, [data-open-popup]");
      if (isPopupTrigger) {
        setTimeout(trySetFormURL, 800); // đợi popup render xong
      }
    });
  });
})();
</script>
<!-- Flickity CDN -->
<script type="text/javascript" src="https://unpkg.com/flickity@2.2.1/dist/flickity.pkgd.min.js"></script>

<script>
document.addEventListener("DOMContentLoaded", function() {
  let tocdo = 2;

  const sliders = document.querySelectorAll('.slider-chay-muot, .slider-chay-muot1');

  sliders.forEach((slider) => {
    let trang_thai_dung_lai = false;

    let flickity_chay = new Flickity(slider, {
      autoPlay: false,
      prevNextButtons: true,
      pageDots: false,
      draggable: true,
      wrapAround: true,
      selectedAttraction: 0.015,
      friction: 0.25
    });

    flickity_chay.x = 0;

    const cap_nhat_slider = () => {
      if (trang_thai_dung_lai) return;
      if (flickity_chay.slides) {
        flickity_chay.x = (flickity_chay.x - tocdo) % flickity_chay.slideableWidth;
        flickity_chay.selectedIndex = flickity_chay.dragEndRestingSelect();
        flickity_chay.updateSelectedSlide();
        flickity_chay.settle(flickity_chay.x);
      }
      window.requestAnimationFrame(cap_nhat_slider);
    };

    const dung_lai = () => { trang_thai_dung_lai = true; };
    const play = () => {
      if (trang_thai_dung_lai) {
        trang_thai_dung_lai = false;
        window.requestAnimationFrame(cap_nhat_slider);
      }
    };

    slider.addEventListener('mouseenter', dung_lai);
    slider.addEventListener('focusin', dung_lai);
    slider.addEventListener('mouseleave', play);
    slider.addEventListener('focusout', play);

    flickity_chay.on('dragStart', () => {
      trang_thai_dung_lai = true;
    });

    cap_nhat_slider();
  });
});
</script>
