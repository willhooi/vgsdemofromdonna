/* ---------------------------------------------- */
/* css trang tạo mini app */
.box-taoMiniApp{
	font-size:16px;
  border: 2px solid rgba(248, 217, 228, 0.5);
	border-radius:16px;
	padding:30px;
	transition: box-shadow 0.1s ease;
}

.box-taoMiniApp:hover {
	border: 2px solid #ff547f ;
	cursor:pointer;
  box-shadow: 0 12px 24px rgba(248, 217, 228, 0.9);
}

/*css ngành bán lẻ*/
.bg-form-ban-le{
	border-radius:12px;
	background-image: url('https://cnv.vn/wp-content/uploads/2025/08/Asset-12-5.png');
  background-size: cover;       /* co ảnh vừa khít */
  background-position: center;  /* canh giữa ảnh */
  background-repeat: no-repeat; /* không lặp lại */
}

/*disable button khi submit */
.wpcf7 form.submitting .wpcf7-submit {
  pointer-events: none;  /* không click được */
  opacity: 0.6;          /* làm mờ đi */
}

/*css bảng giá ở trang bảng giá*/

/* ===== Pricing Table (CNV) ===== */
.cnv-table{width:100%;border-collapse:collapse;font-family:Arial,Helvetica,sans-serif}
.cnv-table th,.cnv-table td{border:1px solid #eee;padding:12px 14px;text-align:center}
.cnv-table thead th{background:#f97b98;color:#fff;font-weight:700}
.cnv-table thead th:first-child{text-align:left}
.cnv-table tbody td:first-child{text-align:left}
.cnv-table tbody tr:nth-child(odd){background:#fff5f7}

/* Mobile responsive: stack rows as cards */
@media (max-width: 768px){
  .cnv-wrap{overflow:hidden}
  .cnv-table, .cnv-table thead, .cnv-table tbody, .cnv-table th, .cnv-table td, .cnv-table tr{display:block}
  .cnv-table thead{position:absolute;top:-9999px;left:-9999px}
  .cnv-table tr{background:#fff;border:1px solid #eee;margin-bottom:14px;border-radius:10px;overflow:hidden}
  .cnv-table td{border:none;border-bottom:1px solid #f2f2f2;text-align:left;padding:10px 14px}
  .cnv-table td:last-child{border-bottom:none}
  .cnv-table td::before{
    content:attr(data-label);
    display:block;
    font-size:16px;
    color:#666;
    margin-bottom:4px;
    text-transform:none
  }
}

/* NTH - Điều chỉnh hiển thị của menu tính năng */

.tinh-nang-row .tinhnang-iconbox,
.tinh-nang-row .tinhnang-iconbox .icon-box-text,
.tinh-nang-row .tinhnang-iconbox p,
.tinh-nang-row .tinhnang-iconbox h3 {
  text-align: left !important;
}

.tinh-nang-row .tinhnang-iconbox {
  margin-bottom: 14px;       
}

.tinh-nang-row .tinhnang-iconbox .icon-box {
  align-items: flex-start;
}
.tinh-nang-row .tinhnang-iconbox .icon-box-text {
  padding-left: 12px;
}

.tinh-nang-row .tinhnang-iconbox .icon-box-text,
.tinh-nang-row .tinhnang-iconbox .icon-box-img {
  line-height: 1.35;
}

.tinh-nang-row .tinh-nang-c1 {
  padding-right: 18px;
}
.tinh-nang-row .tinh-nang-c2 {
  padding-left: 18px;
}

@media (max-width: 849px) {
  .tinh-nang-row .tinh-nang-c1,
  .tinh-nang-row .tinh-nang-c2 {
    padding-left: 0;
    padding-right: 0;
  }
}

